{
  "name": "verity-api",
  "version": "1.0.1",
  "description": "TypeScript/JavaScript SDK for Verity API - Medicare coverage policies and prior authorization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "guard:release-tag": "node -e \"const pkg=require('./package.json'); const expected='v'+pkg.version; const actual=process.env.GITHUB_REF_NAME; if (actual !== expected) { throw new Error('Release ref '+(actual || '<unset>')+' does not match package version '+expected); }\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node test/basic.js",
    "prepublishOnly": "npm run lint && npm run format:check && npm run build"
  },
  "keywords": [
    "verity",
    "medicare",
    "healthcare",
    "prior-authorization",
    "medical-codes",
    "coverage-policy"
  ],
  "author": "Verity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backworkai/verity-ts.git"
  },
  "bugs": {
    "url": "https://github.com/backworkai/verity-ts/issues"
  },
  "homepage": "https://verity.backworkai.com",
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^20.19.30",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "effect": "^3.21.2"
  }
}
